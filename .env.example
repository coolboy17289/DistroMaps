# DistroMap Environment Configuration
# Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=distromap
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Backend API ──────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost

# ─── Frontend ─────────────────────────────────────────────────────────
FRONTEND_PORT=80

# ─── AI / Workers ─────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── GitHub (for higher API rate limits in the crawler) ───────────────
GITHUB_TOKEN=

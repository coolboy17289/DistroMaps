{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vue",
  "outputDirectory": "frontend-vue/dist",
  "installCommand": "npm install && npm --prefix frontend-vue install",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5",
      "includeFiles": "data.json"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|data\\.json|favicon\\.svg|icons\\.svg|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/data.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
